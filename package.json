{
  "name": "peckish",
  "version": "0.1.0",
  "description": "Peckish — AI ordering agent for DoorDash. Terminal chat, local web app, and MCP server over dd-cli + Claude.",
  "type": "module",
  "private": true,
  "bin": {
    "peckish": "./dist/index.js",
    "peckish-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "web": "tsx src/web.ts",
    "mcp": "tsx src/mcp.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
