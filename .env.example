# Copy to your shell profile or export before `npm run dev` / `npm run web`.
# The app reads these from the environment (it does not load .env itself).

# Required for terminal + web surfaces — your Anthropic API key.
# (The MCP surface needs no key: Claude Desktop supplies the model.)
ANTHROPIC_API_KEY=

# Optional overrides
# DD_AGENT_MODEL=claude-sonnet-5      # or claude-opus-4-8 for max quality
# DD_AGENT_EFFORT=medium              # low | medium | high | xhigh | max
# DD_CLI_PATH=~/.local/bin/dd-cli
# PECKISH_PORT=4747
