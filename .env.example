# Copy to your shell profile or export before `npm run dev`.
# The app reads these from the environment (it does not load .env itself).

# Required — your Anthropic API key (or sign in once with `ant auth login`)
ANTHROPIC_API_KEY=

# Optional overrides
# DD_AGENT_MODEL=claude-opus-4-8
# DD_CLI_PATH=~/.local/bin/dd-cli
